#!/usr/bin/env node

// beastctl — Beast System 3.0 CLI (single-file implementation)

import { Command } from "commander";
import axios, { Method } from "axios";
import fs from "fs";
import path from "path";

const program = new Command();
const HOME = process.env.HOME || process.env.USERPROFILE || ".";
const CONFIG_DIR = path.join(HOME, ".beastctl");
const CONFIG_PATH = path.join(CONFIG_DIR, "config.json");

/* -------------------------------------------------------
   CONFIG + API HELPERS
------------------------------------------------------- */

type BeastctlConfig = {
  base_url?: string;
  token?: string;
  api_key?: string;
  [key: string]: any;
};

function loadConfig(): BeastctlConfig {
  if (!fs.existsSync(CONFIG_PATH)) return {};
  try {
    return JSON.parse(fs.readFileSync(CONFIG_PATH, "utf8"));
  } catch {
    return {};
  }
}

function saveConfig(cfg: BeastctlConfig) {
  if (!fs.existsSync(CONFIG_DIR)) {
    fs.mkdirSync(CONFIG_DIR, { recursive: true });
  }
  fs.writeFileSync(CONFIG_PATH, JSON.stringify(cfg, null, 2), "utf8");
}

async function api(
  path: string,
  method: Method = "GET",
  data: any = null,
  query: Record<string, any> = {}
) {
  const config = loadConfig();
  const base = config.base_url || "http://localhost:3000";

  const url = new URL(path, base);
  Object.entries(query).forEach(([k, v]) => {
    if (v !== undefined && v !== null && v !== "") {
      url.searchParams.set(k, String(v));
    }
  });

  const headers: Record<string, string> = {};
  if (config.token) headers["Authorization"] = `Bearer ${config.token}`;
  if (config.api_key) headers["X-API-Key"] = config.api_key;

  const res = await axios({
    url: url.toString(),
    method,
    data,
    headers,
  });

  return res.data;
}

function printOutput(data: any, format: string | undefined) {
  switch (format) {
    case "raw":
      process.stdout.write(typeof data === "string" ? data : JSON.stringify(data));
      break;
    case "yaml":
      // lightweight inline YAML-ish (no external deps)
      console.log(JSON.stringify(data, null, 2)); // swap with real YAML if you like
      break;
    case "pretty":
      console.log(JSON.stringify(data, null, 2));
      break;
    case "json":
    default:
      console.log(JSON.stringify(data, null, 2));
      break;
  }
}

