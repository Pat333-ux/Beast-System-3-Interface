import express, { Request, Response } from "express";

const router = express.Router();

// In-memory identity registry (replace with DB or identity-record.json)
const IDENTITY_REGISTRY: any[] = [];

/**
 * GET /identity/registry
 * Retrieve identity records with optional filters.
 */
router.get("/identity/registry", async (req: Request, res: Response) => {
  try {
    const { identity_id, trust_min, attribute_key, attribute_value, limit } = req.query;

    let records = [...IDENTITY_REGISTRY];

    // Filter by identity_id
    if (identity_id) {
      records = records.filter((r) => r.identity_id === identity_id);
    }

    // Filter by minimum trust score
    if (trust_min) {
      records = records.filter((r) => r.trust_score >= Number(trust_min));
    }

    // Filter by attribute key/value
    if (attribute_key && attribute_value) {
      records = records.filter(
        (r) => r.attributes?.[attribute_key as string] === attribute_value
      );
    }

    // Limit results
    if (limit) {
      records = records.slice(0, Number(limit));
    }

    return res.status(200).json({
      status: "ok",
      count: records.length,
      records,
    });

  } catch (err) {
    console.error("identity registry error:", err);
    return res.status(500).json({
      status: "error",
      reason: "internal_error",
    });
  }
});

/**
 * POST /identity/registry
 * Register or update an identity record.
 */
router.post("/identity/registry", async (req: Request, res: Response) => {
  try {
    const { identity_id, attributes, credentials, lineage, trust_score } = req.body || {};

    if (!identity_id || !attributes || !credentials) {
      return res.status(400).json({
        status: "rejected",
        reason: "missing_required_fields",
        missing: {
          identity_id: !identity_id,
          attributes: !attributes,
          credentials: !credentials,
        },
      });
    }

    // Check if identity already exists
    const existing = IDENTITY_REGISTRY.find((r) => r.identity_id === identity_id);

    if (existing) {
      // Update existing record
      existing.attributes = attributes;
      existing.credentials = credentials;
      existing.lineage = lineage || existing.lineage;
      existing.trust_score = trust_score || existing.trust_score;
      existing.updated_at = Date.now();

      return res.status(200).json({
        status: "updated",
        record: existing,
      });
    }

    // Create new identity record
    const entry = {
      identity_id,
      attributes,
      credentials,
      lineage: lineage || {},
      trust_score: trust_score || 100,
      created_at: Date.now(),
      updated_at: Date.now(),
    };

    IDENTITY_REGISTRY.push(entry);

    return res.status(201).json({
      status: "registered",
      record: entry,
    });

  } catch (err) {
    console.error("identity registry write error:", err);
    return res.status(500).json({
      status: "error",
      reason: "internal_error",
    });
  }
});

export default router;
