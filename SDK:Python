    class OAuth:
        def __init__(self, parent):
            self.parent = parent

        def register(self, client_name, redirect_uris, scopes=None, metadata=None):
            return self.parent._request(
                "/integrations/oauth/register",
                "POST",
                {
                    "client_name": client_name,
                    "redirect_uris": redirect_uris,
                    "scopes": scopes or [],
                    "metadata": metadata or {},
                },
            )

        def authorize(self, client_id, redirect_uri, user_id, scope=""):
            return self.parent._request(
                "/integrations/oauth/authorize",
                "POST",
                {
                    "client_id": client_id,
                    "redirect_uri": redirect_uri,
                    "user_id": user_id,
                    "scope": scope,
                },
            )

        def token(self, client_id, client_secret, code):
            return self.parent._request(
                "/integrations/oauth/token",
                "POST",
                {
                    "client_id": client_id,
                    "client_secret": client_secret,
                    "code": code,
                    "grant_type": "authorization_code",
                },
            )

        def introspect(self, access_token):
            return self.parent._request(
                "/integrations/oauth/introspect",
                "POST",
                {"access_token": access_token},
            )

