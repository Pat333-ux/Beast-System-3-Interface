# Beast System 3.0 — Official Python SDK (Single File)

import json
import urllib.parse
import urllib.request


class Beast:
    def __init__(self, base_url="http://localhost:3000", token=None, api_key=None):
        self.base_url = base_url.rstrip("/")
        self.token = token
        self.api_key = api_key

    # -------------------------------------------------------
    # INTERNAL REQUEST WRAPPER
    # -------------------------------------------------------
    def _request(self, path, method="GET", body=None, query=None):
        url = f"{self.base_url}{path}"

        if query:
            qs = urllib.parse.urlencode({k: v for k, v in query.items() if v is not None})
            url = f"{url}?{qs}"

        headers = {"Content-Type": "application/json"}
        if self.token:
            headers["Authorization"] = f"Bearer {self.token}"
        if self.api_key:
            headers["X-API-Key"] = self.api_key

        data = None
        if body is not None:
            data = json.dumps(body).encode("utf-8")

        req = urllib.request.Request(url, data=data, headers=headers, method=method)

        try:
            with urllib.request.urlopen(req) as res:
                raw = res.read().decode("utf-8")
                return json.loads(raw) if raw else {}
        except urllib.error.HTTPError as e:
            raw = e.read().decode("utf-8")
            raise Exception(raw)

    # -------------------------------------------------------
    # OPS ENGINE
    # -------------------------------------------------------
    class Ops:
        def __init__(self, parent):
            self.parent = parent

        def dispatch(self, task_type, actor_id, payload=None):
            return self.parent._request(
                "/ops/dispatch",
                "POST",
                {"task_type": task_type, "actor_id": actor_id, "payload": payload or {}},
            )

        def status(self, dispatch_id):
            return self.parent._request("/ops/status", "GET", None, {"dispatch_id": dispatch_id})

        def queue_next(self):
            return self.parent._request("/ops/queue/next", "POST")

        def complete(self, dispatch_id, outcome, result=None, failure_reason=None):
            return self.parent._request(
                "/ops/complete",
                "POST",
                {
                    "dispatch_id": dispatch_id,
                    "outcome": outcome,
                    "result": result or {},
                    "failure_reason": failure_reason,
                },
            )

    # -------------------------------------------------------
    # AUDIT ENGINE
    # -------------------------------------------------------
    class Audit:
        def __init__(self, parent):
            self.parent = parent

        def submit(self, event_type, actor_id, target_id=None, payload=None, metadata=None):
            return self.parent._request(
                "/audit/submit",
                "POST",
                {
                    "event_type": event_type,
                    "actor_id": actor_id,
                    "target_id": target_id,
                    "payload": payload or {},
                    "metadata": metadata or {},
                },
            )

        def logs(self, **filters):
            return self.parent._request("/audit/logs", "GET", None, filters)

        def chain(self, **filters):
            return self.parent._request("/audit/chain", "GET", None, filters)

        def attest(self, **params):
            return self.parent._request("/audit/attest", "POST", params)

        def verify(self, attestation_id):
            return self.parent._request(
                "/audit/attest/verify", "POST", {"attestation_id": attestation_id}
            )

